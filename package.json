{
	"name": "noriture",
	"private": true,
	"version": "1.0.0",
	"homepage": "https://madcampos.github.io/noriture/",
	"keywords": [
		"app",
		"utilities",
		"tools",
		"rss",
		"feed"
	],
	"author": "madcampos",
	"license": "MIT",
	"browser": "./dist/index.html",
	"type": "module",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"bootstrap:browser": "playwright install chromium",
		"bootstrap:types": "wrangler types server/env.d.ts",
		"bootstrap:certs": "mkdir certs && mkcert -key-file=certs/server.key -cert-file=certs/server.crt localhost",
		"bootstrap": "pnpm run bootstrap:certs && pnpm run bootstrap:types && pnpm run bootstrap:browser",

		"start": "vite",

		"format": "dprint fmt",

		"typecheck": "tsc --noEmit",
		"lint:js": "oxlint --fix",
		"lint": "pnpm run typecheck && pnpm run lint:js",

		"test": "vitest",

		"prepreview": "pnpm run build",
		"preview": "vite preview --port 3000",
		"build": "vite build",

		"deploy": "wrangler deploy --minify --env=''"
	},
	"dependencies": {
		"@mozilla/readability": "0.6.0",
		"iconify-icon": "3.0.2",
		"idb": "8.0.3",
		"lit": "3.3.2",
		"open-props": "1.7.23"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "1.31.2",
		"@vitest/browser-playwright": "4.1.4",
		"oxlint": "1.59.0",
		"oxlint-tsgolint": "0.20.0",
		"typed-query-selector": "2.12.1",
		"typescript": "6.0.2",
		"vite": "8.0.8",
		"vitest": "4.1.4",
		"vitest-browser-lit": "1.0.1",
		"wrangler": "4.81.1"
	},
	"overrides": {
		"hasown": "npm:@nolyfill/hasown@^1",
		"string.prototype.matchall": "npm:@nolyfill/string.prototype.matchall@^1",
		"is-core-module": "npm:@nolyfill/is-core-module@^1",
		"safe-buffer": "npm:@nolyfill/safe-buffer@^1"
	}
}
